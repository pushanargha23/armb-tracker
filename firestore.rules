rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: readable by authenticated users, writable by owner or admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Tasks: readable by authenticated users, writable by admin
    // Assigned user can only update completed and status fields
    match /tasks/{taskId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      allow update: if request.auth != null &&
        resource.data.assignedTo == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['completed', 'status']);
    }

    // TimeLogs: readable by authenticated users, writable by owner or admin
    match /timeLogs/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
  }
}
